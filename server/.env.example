# Port on which the Express backend server listens
PORT=5000

# MongoDB Atlas connection string URI
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/resonance

# Secret key used for signing and verifying JWT tokens
JWT_SECRET=your_jwt_signing_secret_key_here

# Running environment mode (development | production)
NODE_ENV=development

# Origin URL of the React client (used for CORS setup)
CLIENT_URL=http://localhost:5173

# API Key for OpenAI services (primary provider)
OPENAI_API_KEY=your_openai_api_key_here

# API Key for Google Gemini services (automatic fallback provider)
GEMINI_API_KEY=your_gemini_api_key_here
